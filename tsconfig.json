{
  "compilerOptions": {
    "outDir": "./dist/",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2017",
    "allowJs": true,
    "jsx": "react",
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "types": ["node", "jest"]
  },
  "ts-node": {
    "esm": true,
    "transpileOnly": true,
    "compilerOptions": {
      "moduleResolution": "node",
      "allowImportingTsExtensions": true
    }
  },
  "include": ["client/**/*", "server/**/*", "offline/**/*", "types/**/*"],
  "exclude": ["node_modules", "dist"]
}
